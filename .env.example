# Database
DATABASE_URL=postgres://maestro:maestro@localhost:5432/maestro

# Anthropic (used by both Goose runtime and direct fallback)
ANTHROPIC_API_KEY=

# Runtime selection
# "goose" (default locally) — uses Goose CLI subprocess
# "anthropic_direct" — calls Anthropic API directly (Docker default; use if Goose CLI proves flaky)
MAESTRO_RUNTIME=goose
GOOSE_BINARY_PATH=/usr/local/bin/goose

# Twilio WhatsApp Sandbox
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Your personal WhatsApp number (with country code, e.g. +14405239475)
# Used in mock failed transactions so the Recovery Orchestrator contacts you during demos.
# Must have joined the Twilio sandbox first.
USER_PHONE_NUMBER=

# ngrok — automatic tunnel for WhatsApp webhooks
# Get your authtoken at: https://dashboard.ngrok.com/get-started/your-authtoken
# Without this, WhatsApp inbound messages won't work (Twilio can't reach localhost).
NGROK_AUTH_TOKEN=
# Reserved ngrok domain (Hobby+ plan). Find yours at: https://dashboard.ngrok.com/domains
# With a fixed domain, the Twilio webhook URL never changes between restarts.
# Example: my-app.ngrok-free.app
NGROK_DOMAIN=
# ngrok API key for auto-cleanup of stale tunnels on startup — get from dashboard.ngrok.com → API
NGROK_API_KEY=

# Server
PORT=8080
FRONTEND_URL=http://localhost:3000

# Workflow engine
MAX_ITERATIONS=5
AGENT_STEP_TIMEOUT_SECS=60
